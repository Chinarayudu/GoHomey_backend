generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  CHEF
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY_FOR_PICKUP
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  REFUNDED
}

enum OrderType {
  DAILY_MEAL
  PANTRY_ITEM
  FUEL_PLAN
  SOCIAL_EVENT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  PICKED_UP
  DELIVERED
  FAILED
}

enum ChefApplicationStatus {
  DRAFT
  PENDING_REVIEW
  PHONE_VETTING
  KITCHEN_AUDIT
  APPROVED
  REJECTED
}

enum DietaryPreference {
  VEG
  NON_VEG
  BOTH
}

enum FaultType {
  CHEF
  DRIVER
  CUSTOMER
}

model User {
  id         String   @id @default(uuid())
  name       String
  phone      String   @unique
  email      String   @unique
  password   String
  role       Role     @default(USER)
  gender     Gender?  @default(OTHER)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  dietary_preference DietaryPreference @default(BOTH)
  fitness_goals      String[]          @default([])

  latitude   Float?
  longitude  Float?

  chef      Chef?
  follows   Follow[]  @relation("UserFollows")
  orders    Order[]
  addresses Address[]
}

model Address {
  id           String   @id @default(uuid())
  user_id      String
  user         User     @relation(fields: [user_id], references: [id])
  label        String // Home, Work, etc.
  address_line String
  city         String
  state        String
  zip_code     String
  latitude     Float?
  longitude    Float?
  is_default   Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}

model Chef {
  id          String   @id @default(uuid())
  name        String
  phone       String   @unique
  email       String   @unique
  password    String
  role        Role     @default(CHEF)
  bio         String?
  rating      Float    @default(0.0)
  is_verified Boolean  @default(false)
  trust_tier  Int      @default(1)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  // Step 1: Personal Info
  primary_cuisine String?

  // Step 2: Kitchen Space
  kitchen_name    String?
  kitchen_address String?
  latitude        Float?
  longitude       Float?
  max_capacity    Int?     @default(10)
  appliances      String[] @default([])

  // Step 3: Security & Verification
  government_id_url    String?
  food_safety_cert_url String?
  kitchen_photo_url    String?

  // Bank details
  bank_name           String?
  bank_account_number String?
  ifsc_code           String?

  // Registration tracking
  application_status ChefApplicationStatus @default(DRAFT)
  registration_step  Int                   @default(1)

  user_id       String?       @unique
  user          User?         @relation(fields: [user_id], references: [id])
  followers     Follow[]      @relation("ChefFollowers")
  meals         DailyMeal[]
  pantry        PantryItem[]
  fuel_slots    FuelSlot[]
  social_events SocialEvent[]
  orders        Order[]
}

model Follow {
  id      String @id @default(uuid())
  user_id String
  chef_id String
  user    User   @relation("UserFollows", fields: [user_id], references: [id])
  chef    Chef   @relation("ChefFollowers", fields: [chef_id], references: [id])

  @@unique([user_id, chef_id])
}

model DailyMeal {
  id              String   @id @default(uuid())
  chef_id         String
  chef            Chef     @relation(fields: [chef_id], references: [id])
  meal_name       String
  type            String // dietary type: VEG, NON_VEG
  service_window  String? // LUNCH, DINNER
  image_url       String?
  price           Float
  slots_total     Int
  slots_remaining Int
  batch_photo_url String? // For proof of batch/pickup
  date            DateTime
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  order_items OrderItem[]
}

model FuelPlan {
  id          String   @id @default(uuid())
  name        String
  goal        String
  description String
  price       Float
  menu_json   Json
  calories    Int?
  protein     Int?
  carbs       Int?
  fat         Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  slots FuelSlot[]
}

model FuelSlot {
  id              String   @id @default(uuid())
  chef_id         String
  chef            Chef     @relation(fields: [chef_id], references: [id])
  plan_id         String
  plan            FuelPlan @relation(fields: [plan_id], references: [id])
  time_slot       String
  capacity        Int
  slots_remaining Int
  created_at      DateTime @default(now())

  order_items OrderItem[]
}

model PantryItem {
  id         String   @id @default(uuid())
  chef_id    String
  chef       Chef     @relation(fields: [chef_id], references: [id])
  name       String
  category   String
  price      Float
  inventory  Int
  image_url  String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  order_items OrderItem[]
}

model SocialEvent {
  id              String   @id @default(uuid())
  chef_id         String
  chef            Chef     @relation(fields: [chef_id], references: [id])
  title           String
  description     String
  date            DateTime
  end_date        DateTime
  location        String
  price           Float
  slots_total     Int
  slots_remaining Int
  social_balance  Boolean  @default(false)
  image_url       String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  order_items OrderItem[]
}

model Order {
  id          String      @id @default(uuid())
  user_id     String
  chef_id     String
  user        User        @relation(fields: [user_id], references: [id])
  chef        Chef        @relation(fields: [chef_id], references: [id])
  order_type  OrderType
  status      OrderStatus @default(PENDING)
  total_price Float
  fault_type  FaultType?
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt

  items    OrderItem[]
  payment  Payment?
  delivery Delivery?
}

model OrderItem {
  id       String @id @default(uuid())
  order_id String
  order    Order  @relation(fields: [order_id], references: [id])

  // Polymorphic-like relation via manual tracking
  item_id  String
  quantity Int
  price    Float // Price at the time of order

  // Relations to actual items (at least one should be populated based on OrderType)
  daily_meal_id   String?
  daily_meal      DailyMeal?   @relation(fields: [daily_meal_id], references: [id])
  pantry_id       String?
  pantry_item     PantryItem?  @relation(fields: [pantry_id], references: [id])
  fuel_slot_id    String?
  fuel_slot       FuelSlot?    @relation(fields: [fuel_slot_id], references: [id])
  social_event_id String?
  social_event    SocialEvent? @relation(fields: [social_event_id], references: [id])
}

model Payment {
  id            String        @id @default(uuid())
  order_id      String        @unique
  order         Order         @relation(fields: [order_id], references: [id])
  amount        Float
  status        PaymentStatus @default(PENDING)
  gateway_id    String? // Razorpay payment ID
  escrow_status String        @default("PENDING") // PENDING, HELD, RELEASED, REFUNDED
  created_at    DateTime      @default(now())
  updated_at    DateTime      @updatedAt
}

model DeliveryPartner {
  id           String   @id @default(uuid())
  name         String // e.g., "Shadowfax"
  phone_number String?
  is_active    Boolean  @default(true)
  api_key      String? // Encrypted API Key securely stored
  base_url     String? // External API base URL
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  deliveries Delivery[]
}

model Delivery {
  id                    String           @id @default(uuid())
  order_id              String           @unique
  order                 Order            @relation(fields: [order_id], references: [id])
  partner_id            String?
  partner               DeliveryPartner? @relation(fields: [partner_id], references: [id])
  external_tracking_id  String? // Stores external delivery tracking code
  external_tracking_url String? // Stores external live map tracking URL
  pickup_time           DateTime?
  delivered_time        DateTime?
  pod_image             String? // Proof of Delivery
  status                DeliveryStatus   @default(PENDING)
  created_at            DateTime         @default(now())
  updated_at            DateTime         @updatedAt
}
